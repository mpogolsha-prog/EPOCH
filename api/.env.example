# EPOCH x402 API Server — Environment Variables

# Solana RPC URL (default: https://api.devnet.solana.com)
RPC_URL=https://api.devnet.solana.com

# Program ID (default: from Anchor build)
PROGRAM_ID=6UR3o2WprrTuvWU1sXywtTixcAJCRsKt1W9Eeg7gYLwk

# Server keypair for signing on-chain transactions (path to JSON keypair file)
# Required for POST /place-lend-order and POST /place-borrow-order
# Local: ~/.config/solana/id.json | Railway: /app/server-keypair.json
SERVER_KEYPAIR_PATH=~/.config/solana/id.json

# x402 payment recipient (default: server wallet address)
EPOCH_PAY_TO=

# Server port (default: 3001)
PORT=3001
