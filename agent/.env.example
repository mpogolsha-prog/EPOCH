# EPOCH API server URL
API_BASE_URL=http://localhost:3001

# Agent keypair paths (Solana JSON keypair files)
# Each agent needs its own keypair with devnet USDC for x402 payments
CARL_KEYPAIR_PATH=~/.config/solana/carl.json
MIKE_KEYPAIR_PATH=~/.config/solana/mike.json
ALICE_KEYPAIR_PATH=~/.config/solana/alice.json

# Agent capital in USDC (default: 10000)
AGENT_CAPITAL_USDC=10000

# Cycle interval in seconds (default: 300 = 5 minutes)
CYCLE_INTERVAL_SECONDS=300

# Term for orders: 7, 14, or 30 (default: 30)
ORDER_TERM_DAYS=30
